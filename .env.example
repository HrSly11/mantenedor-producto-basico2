# Backend
# Opción 1: SQLite (desarrollo local, sin instalar PostgreSQL)
DATABASE_URL=sqlite:///./product_db.sqlite3

# Opción 2: PostgreSQL (producción)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/product_db

# Orígenes permitidos CORS (coma separada). En producción, lista solo tus dominios HTTPS.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Opcional: tamaño del pool SQLAlchemy (PostgreSQL)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Frontend
API_BASE_URL=http://localhost:8000
